# ============================
# Python 基础忽略项
# ============================
__pycache__/
*.pyc
*.pyo
*.pyd
*.pdb
*.so
*.egg-info/

# 虚拟环境
venv/
env/
.venv/
ENV/

# ============================
# RAG 项目相关
# ============================

# 数据集（你的 Excel 医疗数据）
*.xlsx
*.xls

# 临时生成文件 / 缓存文件
*.tmp
*.log
*.cache
cache/
temp/
tmp/

# PDF、PPT（一般不需要放进 Git，文件太大）
*.pdf
*.pptx
*.docx

# 用户上传、下载的中间文件
uploads/
downloads/

# ============================
# 嵌入与向量数据库（非常重要）
# ============================
vector_store/
vector_db/
embeddings/
faiss_index/
*.faiss
*.npy

# ============================
# 环境变量 / 配置文件（可能含 API Key）
# ============================
.env
*.env

# ============================
# VS Code 相关
# ============================
.vscode/
*.code-workspace
